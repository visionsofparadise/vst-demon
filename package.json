{
  "name": "vst-demon",
  "productName": "VST Demon",
  "version": "0.1.0",
  "description": "VST Demon — .vstpreset manager launcher for VST3 plugins",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ./agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ./agent-tsc.js\"",
    "check:verbose": "concurrently \"eslint .\" \"tsc --noEmit\"",
    "lint": "eslint . --fix --cache --format ./agent-eslint.js",
    "lint:verbose": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "unit": "vitest run unit",
    "fetch-cli": "tsx scripts/fetch-cli.ts"
  },
  "author": {
    "name": "Matt Cavender",
    "email": "matt@mattcavender.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.0.0",
    "@stylistic/eslint-plugin": "^2.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "adm-zip": "^0.5.18",
    "concurrently": "^9.2.1",
    "electron": "40.8.0",
    "eslint": "^9.0.0",
    "eslint-plugin-barrel-files": "^3.0.0",
    "eslint-plugin-check-file": "^3.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
